{
	"extends": "@repo/typescript-config/svelte.json",
	"compilerOptions": {
		"paths": {
			"#core": ["../core/src"],
			"#core/*": ["../core/src/*"],

			"#ui": ["../ui/src"],
			"#ui/*": ["../ui/src/*"],

			"#state": ["../state/src"],
			"#state/*": ["../state/src/*"],

			"#features": ["../features/src"],
			"#features/*": ["../features/src/*"]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.svelte",

		"../core/src/**/*.ts",
		"../core/src/**/*.svelte",

		"../ui/src/**/*.ts",
		"../ui/src/**/*.svelte",

		"../state/src/**/*.ts",
		"../state/src/**/*.svelte"
	],
	"exclude": ["node_modules"]
}
