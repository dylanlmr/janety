{
	"name": "@repo/ui",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"exports": {
		"./globals.css": "./src/globals.css",
		"./components/*.svelte": {
			"types": "./src/components/*.svelte",
			"svelte": "./src/components/*.svelte",
			"default": "./src/components/*.svelte"
		},
		"./components/*.svelte.ts": {
			"types": "./src/components/*.svelte.ts",
			"svelte": "./src/components/*.svelte.ts",
			"default": "./src/components/*.svelte.ts"
		},
		"./components/*.ts": {
			"types": "./src/components/*.ts",
			"default": "./src/components/*.ts"
		},
		"./components/*": {
			"types": "./src/components/*/index.ts",
			"svelte": "./src/components/*/index.ts",
			"default": "./src/components/*/index.ts"
		}
	},
	"scripts": {
		"lint": "eslint .",
		"check-types": "svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"dependencies": {
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"mode-watcher": "^1.1.0",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@lucide/svelte": "^1.20.0",
		"@repo/eslint-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^24.13.2",
		"@vitest/browser-playwright": "^4.1.8",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	}
}
