{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "tauri",
	"version": "0.1.0",
	"identifier": "com.dlmr.tauri",
	"build": {
		"beforeDevCommand": "pnpm run dev:vite",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm run build:vite",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "tauri",
				"width": 800,
				"height": 600
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
