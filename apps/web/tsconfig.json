{
	"extends": ["@repo/typescript-config/svelte.json", "./.svelte-kit/tsconfig.json"],
	"compilerOptions": {},
	"include": [
		".svelte-kit/ambient.d.ts",
		".svelte-kit/non-ambient.d.ts",
		".svelte-kit/types/**/$types.d.ts",

		"vite.config.ts",

		"src/**/*.ts",
		"src/**/*.svelte",

		"../../packages/features/src/**/*.ts",
		"../../packages/features/src/**/*.svelte",

		"../../packages/state/src/**/*.ts",
		"../../packages/state/src/**/*.svelte",

		"../../packages/ui/src/**/*.ts",
		"../../packages/ui/src/**/*.svelte"
	],
	"exclude": ["node_modules", "dist", "build"]
}
