{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"build:wasm": "cd ../../crates/janety-core && wasm-pack build --target web --out-dir ../../apps/web/src/lib/wasm --features wasm",
		"build:emscripten": "cd ../../ && emcc crates/janety-core/janet_c/janet.c crates/janety-core/janet_c/janet_wasm.c -o apps/web/src/lib/wasm/janet_vm.js -I crates/janety-core/janet_c -O3 -s WASM=1 -s MODULARIZE=1 -s EXPORT_ES6=1 -s EXPORT_NAME=createJanetVM -s EXPORTED_RUNTIME_METHODS=UTF8ToString,stringToNewUTF8 -s EXPORTED_FUNCTIONS=_free,_malloc -s ALLOW_MEMORY_GROWTH=1",
		"build:engines": "pnpm run build:wasm && pnpm run build:emscripten"
	},
	"dependencies": {
		"@repo/core": "workspace:*",
		"@repo/state": "workspace:*",
		"@repo/ui": "workspace:*",
		"mode-watcher": "^1.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@repo/eslint-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^24.13.2",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16"
	}
}
