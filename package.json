{
  "name": "janety",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean",
    "web:dev": "pnpm --filter web dev",
    "web:dev:host": "pnpm --filter web dev --host",
    "web:build": "pnpm --filter web build",
    "tauri:dev": "pnpm --filter native tauri dev",
    "tauri:build": "pnpm --filter native tauri build",
    "tauri:build:portable": "pnpm --filter native tauri build --no-bundle",
    "tauri:android:dev": "pnpm --filter native tauri android dev",
    "tauri:android:build": "pnpm --filter native tauri android build",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "turbo": "^2.9.17"
  },
  "engines": {
    "node": ">=18"
  }
}
