{
	"name": "tauri-sveltekit-monorepo",
	"private": true,
	"scripts": {
		"build": "pnpm -r run build",
		"lint": "pnpm -r run lint",
		"format": "prettier --write .",
		"check-types": "pnpm -r run check-types",
		"clean": "pnpm dlx rimraf@latest --glob \"**/node_modules\" \"**/.svelte-kit\" \"**/.vite\" \"**/dist\" \"**/build\"",
		"nuke": "pnpm run clean && pnpm dlx rimraf@latest pnpm-lock.yaml && pnpm install",
		"dev": "pnpm --filter web dev",
		"dev:tauri": "pnpm --filter tauri dev",
		"dev:all": "pnpm --filter web --filter tauri --parallel dev"
	},
	"devDependencies": {
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0"
	},
	"packageManager": "pnpm@10.34.3",
	"engines": {
		"node": ">=24.0.0"
	},
	"pnpm": {
		"overrides": {
			"svelte": "^5.56.3",
			"@sveltejs/vite-plugin-svelte": "^7.1.2"
		}
	}
}
